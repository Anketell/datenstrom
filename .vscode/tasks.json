{
  "version": "2.0.0",
  "tasks": [
   {
      "group": "build",
      "type": "shell",
      "label": "bootstrap",
      "command": "time ./scripts/bootstrap.sh",
      "problemMatcher": []
   },
   {
      "group": {
         "kind": "build",
         "isDefault": true
      },
      "type": "shell",
      "label": "make debug",
      "command": "time make -C debug",
      "problemMatcher": {
         "owner": "cpp",
         "fileLocation": [
            "absolute"
         ],
         "pattern": {
            "regexp": "^(.*):(\\d+):(\\d+):\\s+(info|warning|error|fatal error):\\s+(.*)$",
            "file": 1,
            "line": 2,
            "column": 3,
            "severity": 4,
            "message": 5
         }
      }
   },
   {
      "group": {
         "kind": "test",
         "isDefault": true
      },
      "type": "shell",
      "label": "coverage",
      "command": "time ( make -C coverage; ./scripts/coverage.sh ); google-chrome --new-window ${workspaceRoot}/coverage/html/index.html",
      "problemMatcher": {
         "owner": "cpp",
         "fileLocation": [
            "absolute"
         ],
         "pattern": {
            "regexp": "^(.*):(\\d+):(\\d+):\\s+(info|warning|error|fatal error):\\s+(.*)$",
            "file": 1,
            "line": 2,
            "column": 3,
            "severity": 4,
            "message": 5
         }
      }
   },
   {
      "type": "shell",
      "label": "clean",
      "command": "make -C debug clean; make -C coverage clean",
      "problemMatcher": []
   }
]
}